includes:
	- vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
	level: 8
	paths:
		- includes
	excludePaths:
		- tests/_support/_generated
	ignoreErrors:
		# Plugin-defined constants are declared in menupilot.php, outside the analysed paths.
		- '#Constant MENUPILOT_[A-Z_]+ not found\.#'
